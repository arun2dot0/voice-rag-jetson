# Copy to .env and adjust for your device.
#
# These are PREBUILT images (pulled, not compiled). Building faster-whisper /
# piper from source on-device OOM-crashes, so we avoid it:
#   - STT uses Dusty's prebuilt faster-whisper CUDA image (match your L4T tag).
#   - TTS installs piper-tts from pip and runs on CPU, so it needs no base image.
STT_BASE_IMAGE=dustynv/faster-whisper:r36.4.0-cu128-24.04
OLLAMA_IMAGE=dustynv/ollama:r36.4.0

# Voice + LLM models (owned by this project). These are the validated defaults
# for an 8GB Orin Nano with a desktop running — both models fit in the unified
# memory. Larger (small.en / qwen2.5:3b) OOMs unless you free memory first; see
# README "Model sizing" and FINDINGS.md.
WHISPER_MODEL=base.en
PIPER_VOICE=en_US-lessac-high
CHAT_MODEL=qwen2.5:1.5b

# Embedding model pulled into ollama. Only needed if your rag-rss-search service
# uses THIS ollama for embeddings (OPENAI_BASE_URL -> this host). The DB schema /
# dimension is rag-rss-search's concern, not this project's.
EMBEDDING_MODEL=nomic-embed-text

# External RAG search service (rag-rss-search). Where the orchestrator sends
# /search. Default reaches the host from inside the compose network.
RAG_URL=http://host.docker.internal:9000
